# 根目录：供 docker-compose / docker-compose.prod 读取（复制为 .env，勿提交）
# 与 backend/.env 分工：此处为编排与 TLS 路径；应用密钥与 FRONTEND_URL 等在 backend/.env

# 与 backend/.env 中 DB_PASSWORD 保持一致（MySQL root）
DB_PASSWORD=change-me

# ---------- 仅 docker-compose.prod.yml ----------
# 公网域名（与 DNS、证书 CN 一致）
DOMAIN=starloom.com.cn

# 可选：后端镜像构建时换 PyPI 源（阿里云 pip 偶发 Broken pipe 时可改用清华）
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple/
# PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn

# 容器内证书路径（一般无需改，与 https 模板一致）
SSL_CERTIFICATE=/etc/nginx/ssl/fullchain.pem
SSL_CERTIFICATE_KEY=/etc/nginx/ssl/privkey.pem

# 主机上 PEM 文件路径（Let's Encrypt 示例；自签则改为你生成的路径）
# SSL_FULLCHAIN_HOST=/etc/letsencrypt/live/starloom.com.cn/fullchain.pem
# SSL_PRIVKEY_HOST=/etc/letsencrypt/live/starloom.com.cn/privkey.pem

# 本地试跑可先在 deploy/ssl/ 放置 fullchain.pem / privkey.pem，再注释掉上面两行使用默认相对路径
#
# Let’s Encrypt（在服务器用 scripts/issue-letsencrypt-webroot.sh 申请后可填）：
# SSL_FULLCHAIN_HOST=/etc/letsencrypt/live/starloom.com.cn/fullchain.pem
# SSL_PRIVKEY_HOST=/etc/letsencrypt/live/starloom.com.cn/privkey.pem
# 可选：export CERTBOT_EMAIL=you@example.com 再跑 issue 脚本（免 --register-unsafely-without-email）
