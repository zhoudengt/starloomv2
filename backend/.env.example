# Database (Docker: hostnames; local dev: localhost + mapped ports)
DB_HOST=localhost
DB_PORT=3307
DB_NAME=starloom
DB_USER=root
DB_PASSWORD=123456

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0

# LLM
LLM_PLATFORM=coze
COZE_API_BASE=https://api.coze.cn
COZE_ACCESS_TOKEN=
COZE_BOT_ID_DAILY=
COZE_BOT_ID_REPORT=
COZE_BOT_ID_COMPATIBILITY=
COZE_BOT_ID_ANNUAL=
COZE_BOT_ID_CHAT=
BAILIAN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_APP_ID=
BAILIAN_API_KEY=

# Payment (xorpay)
XORPAY_APP_ID=
XORPAY_APP_SECRET=
XORPAY_NOTIFY_URL=https://yourdomain.com/api/v1/payment/notify
XORPAY_API_BASE=https://xorpay.com

# App
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-long-random-string
FRONTEND_URL=http://localhost:5173
JWT_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
