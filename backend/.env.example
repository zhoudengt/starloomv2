# Database (Docker: hostnames; local dev: localhost + mapped ports)
DB_HOST=localhost
DB_PORT=3307
DB_NAME=starloom
DB_USER=root
DB_PASSWORD=123456

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0

# 全局限流（RateLimitMiddleware，需 Redis）。触顶返回 429 + Retry-After
# RATE_LIMIT_WINDOW_SECONDS=60
# RATE_LIMIT_PAYMENT_CREATE_PER_MINUTE=12
# RATE_LIMIT_FREE_PER_MINUTE=60
# RATE_LIMIT_DAILY_PERSONAL_PER_MINUTE=3
# RATE_LIMIT_QUICKTEST_PER_MINUTE=20
# RATE_LIMIT_PAID_REPORT_CHAT_PER_MINUTE=20

# 每日公开运势：北京时间 cron 预写 Redis+MySQL（与 GET /daily/* 同一套 ensure 逻辑）
# 开发时若与 uvicorn --reload 冲突可设为 false
DAILY_PREFETCH_ENABLED=true
DAILY_PREFETCH_HOUR_BEIJING=0
DAILY_PREFETCH_MINUTE_BEIJING=5

# LLM — 百炼智能体（系统提示词在控制台配置，代码只传用户参数）
LLM_PLATFORM=bailian
BAILIAN_API_KEY=your-dashscope-api-key

# 五个百炼应用 ID（智能体）
BAILIAN_APP_ID_DAILY=
BAILIAN_APP_ID_PERSONALITY=
BAILIAN_APP_ID_COMPATIBILITY=
BAILIAN_APP_ID_ANNUAL=
BAILIAN_APP_ID_CHAT=
BAILIAN_APP_ID_PLANNER=
BAILIAN_APP_ID_PROFILE_EXTRACTOR=

# Coze（可选，当 LLM_PLATFORM=coze 时使用）
COZE_API_BASE=https://api.coze.cn
COZE_ACCESS_TOKEN=
COZE_BOT_ID_DAILY=
COZE_BOT_ID_REPORT=
COZE_BOT_ID_COMPATIBILITY=
COZE_BOT_ID_ANNUAL=
COZE_BOT_ID_CHAT=

# 兼容旧配置（仅 Coze 主 + 百炼兜底单应用时使用）
BAILIAN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_APP_ID=

# Payment (虎皮椒 xunhupay.com) — 微信与支付宝各一对，可只配其一
# 商户后台：登录 https://admin.xunhupay.com/ ｜注册 https://admin.xunhupay.com/sign-up.html
# 官网说明：https://www.xunhupay.com/
XUNHUPAY_APPID_WECHAT=
XUNHUPAY_APPSECRET_WECHAT=
XUNHUPAY_APPID_ALIPAY=
XUNHUPAY_APPSECRET_ALIPAY=
# 须公网 HTTPS，且与处理下单的后端为同一实例/同一数据库；本地联调可用 ngrok
# XUNHUPAY_NOTIFY_URL=https://xxx.ngrok-free.app/api/v1/payment/notify
XUNHUPAY_NOTIFY_URL=https://yourdomain.com/api/v1/payment/notify
XUNHUPAY_API_BASE=https://api.xunhupay.com

# 真实支付时：FRONTEND_URL / CORS_ORIGINS 与用户实际打开站点一致（return_url、浏览器跨域）
# FRONTEND_URL=https://yourdomain.com
# CORS_ORIGINS=https://yourdomain.com,http://localhost:5173,http://127.0.0.1:5173

# App
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-long-random-string
FRONTEND_URL=http://localhost:5173
JWT_EXPIRE_DAYS=7

# CORS (comma-separated origins)
# 开发: http://localhost:5173,http://127.0.0.1:5173
# 生产: https://yourdomain.com (切勿设为 *)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 首页轮播 GET /articles?carousel=1：无当日发文时回退最近 N 个自然日（北京日期）
# ARTICLE_CAROUSEL_FALLBACK_DAYS=7

# 统一日包（主进程 APScheduler）：北京时间触发 ops.pipeline.run_daily → ops/out/ 抖音物料 + 轮播入库 articles.tags=carousel
# UNIFIED_DAILY_ENABLED=true
# UNIFIED_DAILY_HOUR_BEIJING=0
# UNIFIED_DAILY_MINUTE_BEIJING=20
# 单次 run_daily 最多写入几条轮播文（与 Settings.carousel_max_articles 一致）
# CAROUSEL_MAX_ARTICLES=5

# --- 运营流水线 ops（可选，不配置也能跑模板；见 backend/ops/README.md）---
# OPS_LLM_ENABLED=false
# OPS_BAILIAN_APP_ID=
# OPS_WEIBO_ACCESS_TOKEN=
# OPS_RSS_FEED_URLS=
# OPS_FRONTEND_BASE_URL=
# OPS_TOP_K_ANGLES=5
# OPS_CALENDAR_YAML=

# 万相文生图/视频（DashScope API，使用 BAILIAN_API_KEY；可选 OPS_DASHSCOPE_API_KEY 覆盖）
# OPS_WAN_IMAGE_ENABLED=true
# OPS_WAN_VIDEO_ENABLED=false
# OPS_WAN_IMAGE_MODEL=wan2.6-t2i
# OPS_WAN_VIDEO_MODEL=wan2.6-t2v
# OPS_WAN_IMAGE_SIZE=720*1280
# OPS_WAN_VIDEO_SIZE=720*1280
# OPS_WAN_VIDEO_DURATION_SEC=5
# OPS_DASHSCOPE_API_KEY=
# OPS_DASHSCOPE_WORKSPACE=
# OPS_DASHSCOPE_HTTP_BASE=https://dashscope.aliyuncs.com/api/v1
# OPS_WAN_IMAGE_SLEEP_SEC=4
# OPS_WAN_IMAGE_RETRIES=3
# 轮播图 JPEG 压缩目标上限 KB（抖音约 500）
# OPS_WAN_IMAGE_MAX_KB=500
